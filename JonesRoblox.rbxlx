	HungerRestore = 35,
	FullnessMinutes = 90,
	-- Custom PNG source: Assets/FoodIcons/sandwich.png
	-- Replace ImageAssetId after uploading PNG to Roblox and receiving asset id.
	ImageAssetId = "rbxassetid://91888167350450",
